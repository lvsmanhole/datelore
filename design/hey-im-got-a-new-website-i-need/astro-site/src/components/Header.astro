---
const path = Astro.url.pathname;
const isActive = (href) => path === href || (href !== "/" && path.startsWith(href));
---
<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="wordmark" href="/"><span class="wordmark__mark">✦</span> DateLore</a>
    <nav class="nav" aria-label="Primary">
      <ul>
        <li><a href="/day/05-31" aria-current={isActive('/day') ? 'page' : undefined}>Today</a></li>
        <li><a href="/birthday" aria-current={isActive('/birthday') ? 'page' : undefined}>Your Birthday</a></li>
        <li><a href="/quiz" aria-current={isActive('/quiz') ? 'page' : undefined}>Daily Quiz</a></li>
      </ul>
    </nav>
    <form class="quick-date hide-sm" role="search" aria-label="Jump to a date">
      <label for="qd">Go to date</label>
      <input type="date" id="qd" data-quick-date>
    </form>
  </div>
</header>
