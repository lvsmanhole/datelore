---
// Placeholder homepage for the initial scaffold.
// The real homepage will spotlight TODAY (client-side date detection) per the design spec.
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>DateLore — On this day in history &amp; the day you were born</title>
    <meta
      name="description"
      content="Discover what happened on any date in history, who shares your birthday, your zodiac and generation, plus a daily history quiz."
    />
    <style>
      :root { color-scheme: light; }
      body {
        margin: 0;
        font-family: ui-serif, Georgia, "Times New Roman", serif;
        background: #f7f1e3;
        color: #22202b;
        display: grid;
        min-height: 100vh;
        place-items: center;
        padding: 2rem;
      }
      main { max-width: 40rem; text-align: center; }
      .kicker {
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-size: 0.8rem;
        color: #9a6a2f;
        font-family: ui-sans-serif, system-ui, sans-serif;
      }
      h1 { font-size: clamp(2.2rem, 6vw, 3.4rem); margin: 0.4rem 0; line-height: 1.1; }
      p { font-size: 1.15rem; line-height: 1.6; color: #4a4658; }
      .badge {
        display: inline-block;
        margin-top: 1.5rem;
        padding: 0.5rem 1rem;
        border-radius: 999px;
        background: #22202b;
        color: #f7f1e3;
        font-family: ui-sans-serif, system-ui, sans-serif;
        font-size: 0.95rem;
      }
      footer {
        margin-top: 2.5rem;
        font-size: 0.8rem;
        color: #8a8696;
        font-family: ui-sans-serif, system-ui, sans-serif;
      }
    </style>
  </head>
  <body>
    <main>
      <p class="kicker">DateLore</p>
      <h1>On this day &amp; the day you were born</h1>
      <p>
        What happened in history on any date, who shares your birthday, your zodiac and
        generation, and a daily history quiz. Coming soon.
      </p>
      <span class="badge">Site in development</span>
      <footer>Historical data will be from Wikipedia (CC BY-SA).</footer>
    </main>
  </body>
</html>
