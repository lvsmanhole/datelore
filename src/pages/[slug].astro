---
// One dynamic route serves BOTH day pages (/may-31) and month hubs (/may). They
// share a single segment, so they must live in one route file to avoid an
// ambiguous-route collision; this dispatcher branches on the slug kind, sets the
// per-page <head> (title/description/OG image/JSON-LD), and renders the matching
// content component.
import BaseLayout from '../layouts/BaseLayout.astro';
import DayContent from '../components/DayContent.astro';
import MonthContent from '../components/MonthContent.astro';
import { DATES } from '../data/dates.js';
import { toSlug, monthName, MONTHS } from '../lib/slug';
import {
  breadcrumbSchema,
  dayArticleSchema,
  monthCollectionSchema,
  personSchema,
} from '../lib/jsonld';
import { BUILD_ISO } from '../lib/build-meta';

export function getStaticPaths() {
  const days = Object.keys(DATES).map((key) => ({
    params: { slug: toSlug(key) },
    props: { kind: 'day' as const, key },
  }));
  const months = MONTHS.map((name, i) => ({
    params: { slug: name.toLowerCase() },
    props: { kind: 'month' as const, month: i + 1 },
  }));
  return [...days, ...months];
}

type Props = { kind: 'day'; key: string } | { kind: 'month'; month: number };
const props = Astro.props as Props;

const site = Astro.site!;
const origin = site.origin;
const url = new URL(Astro.url.pathname, site).href;
const abs = (p: string) => new URL(p, site).href;

let title: string;
let description: string;
let ogImage: string;
let jsonld: object[];

if (props.kind === 'day') {
  const { key } = props;
  const [mm, dd] = key.split('-').map(Number);
  const mName = monthName(mm);
  const monthSlug = MONTHS[mm - 1].toLowerCase();
  title = `${mName} ${dd} — On This Day · DateLore`;
  description = `What happened on ${mName} ${dd} — historical events, famous birthdays, deaths, and observances. Plus the zodiac, birthstone, and birth flower for the date.`;
  ogImage = `/og/${toSlug(key)}.png`;
  jsonld = [
    dayArticleSchema({ origin, url, monthName: mName, day: dd, description, image: abs(ogImage), dateModified: BUILD_ISO }),
    personSchema(origin),
    breadcrumbSchema([
      { name: 'DateLore', url: abs('/') },
      { name: mName, url: abs(`/${monthSlug}/`) },
      { name: `${mName} ${dd}`, url },
    ]),
  ];
} else {
  const { month } = props;
  const mName = monthName(month);
  title = `${mName} — Every Day in History · DateLore`;
  description = `Browse every day in ${mName}: what happened on each date, who was born, and the holidays behind the day — a day-by-day almanac of ${mName}.`;
  ogImage = `/og/${MONTHS[month - 1].toLowerCase()}.png`;
  const days = Object.keys(DATES)
    .filter((k) => Number(k.slice(0, 2)) === month)
    .sort((a, b) => Number(a.slice(3)) - Number(b.slice(3)))
    .map((k) => ({ name: `${mName} ${Number(k.slice(3))}`, url: abs(`/${toSlug(k)}/`) }));
  jsonld = [
    monthCollectionSchema({ origin, url, monthName: mName, description, image: abs(ogImage), days }),
    breadcrumbSchema([
      { name: 'DateLore', url: abs('/') },
      { name: mName, url },
    ]),
  ];
}
---
<BaseLayout title={title} description={description} ogImage={ogImage} ogType="article" jsonld={jsonld}>
  {props.kind === 'day'
    ? <DayContent dateKey={props.key} />
    : <MonthContent month={props.month} />}
</BaseLayout>
