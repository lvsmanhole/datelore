---
// src/pages/video-pins/index.astro — internal manual-upload queue (noindex). Lists each
// authored video spec with its expected MP4 filename + copy so the owner can post by hand.
import { loadVideoSpecs, videoSpecToQueueEntry } from '../../lib/video-content';

const specs = loadVideoSpecs();
const entries = specs.map(({ mm, dd, spec }) => videoSpecToQueueEntry(spec, mm, dd));
const byBoard: Record<string, typeof entries> = {};
for (const e of entries) (byBoard[e.board] ??= []).push(e);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Video-pin posting queue — DateLore</title>
    <style>
      body { font: 15px/1.5 system-ui, sans-serif; margin: 2rem; color: #1d0f17; }
      h1 { margin-bottom: 0.25rem; }
      h2 { margin-top: 2rem; border-bottom: 2px solid #d8a23f; padding-bottom: 0.25rem; }
      .pin { display: grid; grid-template-columns: 120px 1fr; gap: 1rem; padding: 1rem 0; border-bottom: 1px solid #eee; }
      .pin img { width: 120px; height: 180px; object-fit: cover; border-radius: 8px; }
      .pin h3 { margin: 0 0 0.25rem; }
      .pin p { margin: 0.25rem 0; }
      .pin a { color: #9a6b1f; word-break: break-all; }
      code { background: #f4efe6; padding: 0 0.25rem; }
    </style>
  </head>
  <body>
    <h1>Video-pin posting queue</h1>
    <p>{entries.length} video pins. Internal tool (noindex). Render with <code>npm run pins:video</code>, then upload each MP4 from <code>video-out/</code> to its board.</p>
    {Object.entries(byBoard).map(([board, list]) => (
      <section>
        <h2>{board} ({list.length})</h2>
        {list.map((e) => (
          <div class="pin">
            <img src={e.cover} alt={e.title} loading="lazy" />
            <div>
              <h3>{e.title} <small>({e.effect})</small></h3>
              <p>{e.description}</p>
              <p>Upload: <code>video-out/{e.mp4}</code></p>
              <p>Link: <a href={e.link}>{e.link}</a></p>
            </div>
          </div>
        ))}
      </section>
    ))}
  </body>
</html>
