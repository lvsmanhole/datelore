---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema, personSchema } from '../lib/jsonld';

const abs = (p: string) => new URL(p, Astro.site).href;
const origin = Astro.site!.origin;
const jsonld = [
  breadcrumbSchema([
    { name: 'DateLore', url: abs('/') },
    { name: 'About', url: abs('/about/') },
  ]),
  personSchema(origin),
];
---
<BaseLayout
  title="About DateLore — The almanac for every day of the year"
  description="DateLore is an independent almanac of every date: what happened in history, who was born, your own birthday's story, and a daily quiz. Here's who we are and where the data comes from."
  ogImage="/og/home.png"
  jsonld={jsonld}
>
  <section class="band band--tight">
    <div class="wrap wrap--narrow stack">
      <p class="eyebrow">About</p>
      <h1 style="font-size:var(--step-5);line-height:.98;">An almanac for every day of the year</h1>
      <p class="lede">
        DateLore is a warm, browsable almanac of all 366 dates. Pick any day and you'll find the
        historical events tied to it, the famous people born on it, the notable deaths and the
        holidays — plus the zodiac, birthstone, and birth flower for that date.
      </p>

      <h2 style="margin-top:var(--s5);">What you can do here</h2>
      <ul class="stack" style="padding-left:1.2em;">
        <li><strong>On This Day</strong> — every date gets its own page of events, birthdays, and observances.</li>
        <li><strong>Your Birthday</strong> — enter your date of birth and reveal your exact age, the weekday you were born, your Chinese zodiac, your generation, and the countdown to your next birthday.</li>
        <li><strong>Daily Quiz</strong> — one "which year did it happen?" question a day, with a streak to keep alive.</li>
        <li><strong>Browse by month</strong> — month hubs gather every day in January through December in one place.</li>
      </ul>

      <h2 style="margin-top:var(--s5);">Who's behind DateLore</h2>
      <p>
        Hi — I'm <strong>Roman Tailor</strong>, and DateLore is mine. I've always been a history
        buff: the kind of person who opens one Wikipedia article and resurfaces an hour later three
        centuries away. Somewhere along the line I realised the thing I loved most was the
        <em>date</em> itself — how a single square on the calendar can hold a revolution, a first
        flight, a hit song, and someone's grandfather's birthday all at once.
      </p>
      <p>
        I built DateLore so anyone could feel that without falling down the rabbit hole. Pick a day —
        any day — and see what the world got up to on it: who was born, what changed, and what's
        worth remembering. No account, no clutter, just the story of the date.
      </p>
      <p>
        It's an independent project I run on my own, and I read every correction that comes in. If
        something looks off, please <a href="/contact/">tell me</a> — I'd genuinely like to fix it.
      </p>

      <h2 style="margin-top:var(--s5);">How it works</h2>
      <p>
        DateLore is a fast, static site — there are no accounts and nothing to sign up for. Your
        birthday calculations and your quiz streak happen entirely in your own browser; that
        information is never sent to me.
      </p>

      <h2 style="margin-top:var(--s5);">Where the data comes from</h2>
      <p>
        The historical events, births, deaths, and observances are drawn from
        <a href="https://en.wikipedia.org/" rel="noopener">Wikipedia</a>, available under the
        <a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">Creative Commons
        Attribution-ShareAlike (CC BY-SA)</a> license. DateLore is an independent project and is not
        affiliated with the Wikimedia Foundation. If you spot something inaccurate, I'd love to hear
        about it — see the <a href="/contact/">contact page</a>.
      </p>

      <p style="margin-top:var(--s5);">
        <a class="btn btn--primary" href="/">Explore today in history →</a>
      </p>
    </div>
  </section>
</BaseLayout>
