---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ReleaseCard from '../../components/ReleaseCard.astro';
import ReleaseDisclosure from '../../components/ReleaseDisclosure.astro';
import { loadReleases, releasesOn, upcoming } from '../../lib/releases';
import { formatReleaseDate, monthLabel, groupByVertical, configuredMonthWindow } from '../../lib/releases-view';
import { breadcrumbSchema, releaseListSchema } from '../../lib/jsonld';

const site = Astro.site!;
const abs = (p: string) => new URL(p, site).href;
const url = new URL(Astro.url.pathname, site).href;

const all = loadReleases();
const today = new Date().toISOString().slice(0, 10); // build-time "today"; nightly rebuild keeps it fresh
const ym = today.slice(0, 7);
// Every month page in the built window, newest-first — gives each /releases/YYYY-MM/
// page an internal link so none are orphaned (Ahrefs "Orphan page" finding).
const months = configuredMonthWindow(today).slice().reverse();
const todays = releasesOn(all, today);
const soon = upcoming(all, today, 500); // soonest-first; grouped into per-vertical sections below
const byVert = groupByVertical(soon);

// Per-vertical upcoming sections, in priority order. Music is omitted until it has a source.
const SECTIONS = [
  { key: 'game', label: 'Games' },
  { key: 'movie', label: 'Movies' },
  { key: 'tv', label: 'TV' },
] as const;
const PER_SECTION = 12;

const title = 'Release Calendar — Games, Movies & TV · DateLore';
const description = 'What releases today and what is coming soon — a curated calendar of notable video game, movie, and TV release dates, past and future.';
const ogImage = '/og/releases.png';
const jsonld = [
  releaseListSchema({
    url,
    name: `New releases around ${formatReleaseDate(today)}`,
    items: soon.slice(0, 40).map((r) => ({ vertical: r.vertical, title: r.title, date: r.date, url: r.sourceUrl, image: r.image })),
  }),
  breadcrumbSchema([
    { name: 'DateLore', url: abs('/') },
    { name: 'Releases', url },
  ]),
];
---
<BaseLayout title={title} description={description} ogImage={ogImage} ogType="website" jsonld={jsonld}>
  <section class="band band--tight">
    <div class="wrap">
      <p class="eyebrow">Release Calendar</p>
      <h1 style="font-size:var(--step-5);">What's releasing</h1>
      <p class="lede" style="margin-top:var(--s3);">Curated game, movie, and TV drops — today, this month, and what's coming next.</p>
    </div>
  </section>

  {todays.length > 0 && (
    <section class="band band--tight band--alt">
      <div class="wrap stack">
        <div class="section-head"><h2 style="font-size:var(--step-2);">Out today · {formatReleaseDate(today)}</h2></div>
        <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--s4);">{todays.map((r) => <ReleaseCard release={r} today={today} />)}</div>
      </div>
    </section>
  )}

  {SECTIONS.map((s) => (
    byVert[s.key].length > 0 && (
      <section class="band band--tight">
        <div class="wrap stack">
          <div class="section-head">
            <h2 style="font-size:var(--step-2);">Upcoming {s.label}</h2>
            <span class="eyebrow eyebrow--soft">{byVert[s.key].length} on the calendar</span>
          </div>
          <div class="grid" style="grid-template-columns:repeat(auto-fill,minmax(280px,1fr));gap:var(--s4);">
            {byVert[s.key].slice(0, PER_SECTION).map((r) => <ReleaseCard release={r} today={today} />)}
          </div>
        </div>
      </section>
    )
  ))}

  <section class="band band--tight band--alt">
    <div class="wrap stack">
      <div class="section-head"><h2 style="font-size:var(--step-2);">Browse by month</h2></div>
      <ul class="release-months">
        {months.map((m) => (
          <li><a href={`/releases/${m}/`} aria-current={m === ym ? 'page' : undefined}>{monthLabel(m)}</a></li>
        ))}
      </ul>
    </div>
  </section>

  <ReleaseDisclosure />

  <style>
    .release-months {
      list-style: none;
      padding: 0;
      display: grid;
      gap: var(--s2);
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    }
    .release-months a {
      display: block;
      padding: var(--s2) var(--s3);
      border: 1px solid var(--line);
      border-radius: var(--r-md, 12px);
      background: var(--paper-2);
      text-decoration: none;
      color: var(--ink);
      transition: border-color .15s ease, background .15s ease;
    }
    .release-months a:hover { border-color: var(--line-strong); background: var(--gold-wash); }
    .release-months a[aria-current='page'] { border-color: var(--gold-deep); color: var(--gold-deep); font-weight: 600; }
  </style>
</BaseLayout>
