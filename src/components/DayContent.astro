---
// The day page body. Rendered by src/pages/[slug].astro for day slugs (e.g.
// /may-31). Pure computation comes from src/lib; BaseLayout + JSON-LD are set by
// the page dispatcher so this stays a presentational component.
import { DATES } from '../data/dates.js';
import { toSlug, monthName, dayOfYear, ordinal, sortKeysByDate, MONTHS } from '../lib/slug';
import { zodiacForDate, birthstoneForMonth, birthFlowerForMonth } from '../lib/reference';
import { buildInsightData } from '../lib/insights';
import { insightProse } from '../lib/insight-voice';
import { corpusStats, percentileRank } from '../lib/corpus-stats';
import { zodiacBlurb, birthstoneBlurb, flowerBlurb } from '../lib/reference-content';
import { loadReleases, releasesForDayPage } from '../lib/releases';
import { verticalLabel } from '../lib/releases-view';
import { BUILD_ISO } from '../lib/build-meta';
import { boldName, isYearName } from '../lib/demote';
import { ESSAYS } from '../data/essays';
import { isPublishable } from '../lib/essays';

const { dateKey } = Astro.props as { dateKey: string };
const key = dateKey;
const entry = DATES[key];
// Chronological timeline (oldest → newest) so the page reads as history rather
// than leading with the most recent — and often tragic — entry.
const events = [...entry.events].sort((a, b) => a.year - b.year);
const births = entry.births.filter((b) => !isYearName(b.name));
const deaths = entry.deaths
  .map((d) => ({ year: d.year, name: boldName(d.text) }))
  .filter((d) => d.name && !isYearName(d.name));
const [mm, dd] = key.split('-').map(Number);
const mName = monthName(mm);
const monthSlug = MONTHS[mm - 1].toLowerCase();
const z = zodiacForDate(mm, dd);
const stone = birthstoneForMonth(mm);
const flower = birthFlowerForMonth(mm);
const doy = dayOfYear(mm, dd);
const _corpus = corpusStats();
const _eventYears = entry.events.map((e) => e.year).filter((y) => Number.isFinite(y));
const _spanYears = _eventYears.length ? Math.max(..._eventYears) - Math.min(..._eventYears) : 0;
const historyPercentile = percentileRank(_spanYears, _corpus.spanYearsAsc);
const currentYear = new Date(BUILD_ISO).getUTCFullYear();
const insightProseText = insightProse(buildInsightData(entry, mm, dd, { historyPercentile, currentYear }));
const reviewedLabel = new Date(BUILD_ISO).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const releaseGroups = releasesForDayPage(loadReleases(), mm, dd);

const essayMod = ESSAYS[key];
const essay = essayMod && isPublishable(essayMod.frontmatter) ? essayMod : null;
const EssayBody = essay?.Content;
const essayReviewedLabel = essay
  ? new Date(essay.frontmatter.reviewedOn).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : '';

const sorted = sortKeysByDate(Object.keys(DATES));
const i = sorted.indexOf(key);
const prevKey = sorted[(i - 1 + sorted.length) % sorted.length];
const nextKey = sorted[(i + 1) % sorted.length];
const label = (k: string) => {
  const [m, d] = k.split('-').map(Number);
  return `${monthName(m)} ${d}`;
};

const shareTitle = `On This Day — ${mName} ${dd} · DateLore`;

// AEO: a self-contained, extractable answer to "what happened on <date>?", built
// from the page's own facts (no invented claims). AI engines pull the first direct
// answer they see, so this leads the body under a question-phrased heading.
const birthNames = births.slice(0, 3).map((b) => b.name);
const nameList =
  birthNames.length <= 1
    ? birthNames.join('')
    : `${birthNames.slice(0, -1).join(', ')} and ${birthNames[birthNames.length - 1]}`;
const eventYears = events.map((e) => e.year);
const yearSpan = eventYears.length
  ? Math.min(...eventYears) === Math.max(...eventYears)
    ? `in ${eventYears[0]}`
    : `between ${Math.min(...eventYears)} and ${Math.max(...eventYears)}`
  : '';
const answer = [
  `${mName} ${dd} is the ${ordinal(doy)} day of the year.`,
  events.length
    ? `It marks ${events.length} notable event${events.length > 1 ? 's' : ''} in history, dated ${yearSpan}.`
    : '',
  birthNames.length ? `Famous people born on ${mName} ${dd} include ${nameList}.` : '',
].filter(Boolean).join(' ');
---
<!-- ===== Date header ===== -->
<section class="band band--tight">
  <div class="wrap">
    <p class="eyebrow">On This Day · The {ordinal(doy)} day of the year</p>
    <div class="date-head" style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:var(--s4);margin-top:var(--s3);">
      <h1 style="font-size:var(--step-6);line-height:.95;">
        {mName} <span style="color:var(--gold-deep);">{dd}</span>
      </h1>
      <button class="btn btn--ghost btn--sm" data-share data-share-title={shareTitle} aria-label="Share this date">
        <svg class="btn__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><path d="M8.6 13.5l6.8 4M15.4 6.5l-6.8 4"/></svg>
        Share
      </button>
    </div>
    <p class="lede" style="margin-top:var(--s3);">{entry.lede}</p>
    <div class="badges" style="margin-top:var(--s5);">
      <span class="badge"><span class="badge__glyph">{z.glyph}</span><span class="badge__text"><span class="badge__label">Zodiac</span><span class="badge__value">{z.sign}</span></span></span>
      <span class="badge"><span class="badge__glyph">◈</span><span class="badge__text"><span class="badge__label">Birthstone</span><span class="badge__value">{stone}</span></span></span>
      <span class="badge badge--coral"><span class="badge__glyph">❀</span><span class="badge__text"><span class="badge__label">Birth flower</span><span class="badge__value">{flower}</span></span></span>
    </div>
    <p class="muted" style="margin-top:var(--s4);font-size:var(--step--1);">
      Compiled &amp; reviewed by <a href="/about/" rel="author" style="color:var(--gold-deep);">Roman Tailor</a> · Last reviewed {reviewedLabel}
    </p>
  </div>
</section>

<!-- ===== Direct answer (AEO: question header + extractable summary) ===== -->
<section class="band band--tight">
  <div class="wrap">
    <h2 style="font-size:var(--step-2);">What happened on {mName} {dd}?</h2>
    <p class="lede" style="margin-top:var(--s2);">{answer}</p>
  </div>
</section>

<!-- ===== Marquee editorial (original lede essay, reviewed only) ===== -->
{essay && EssayBody && (
  <section class="band band--tight">
    <div class="wrap">
      <div class="section-head"><h2 style="font-size:var(--step-3);">{essay.frontmatter.title}</h2></div>
      <div class="essay-prose stack" style="margin-top:var(--s4);max-width:68ch;">
        <EssayBody />
      </div>
      <p class="muted" style="margin-top:var(--s4);font-size:var(--step--1);">
        Written &amp; reviewed by <a href="/about/" rel="author" style="color:var(--gold-deep);">{essay.frontmatter.author}</a> · Reviewed {essayReviewedLabel}
      </p>
    </div>
  </section>
)}

<!-- ===== The shape of the day (computed) + reference depth ===== -->
<section class="band band--tight band--alt">
  <div class="wrap stack">
    <div class="section-head"><h2 style="font-size:var(--step-2);">The shape of the day</h2></div>
    <p class="lede" style="margin-top:0;">{insightProseText}</p>
    <div class="grid" style="grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:var(--s4);margin-top:var(--s2);">
      <div class="card card--pad"><p class="eyebrow">Zodiac · {z.sign}</p><p style="margin-top:var(--s2);">{zodiacBlurb(z.sign)}</p></div>
      <div class="card card--pad"><p class="eyebrow">Birthstone · {stone}</p><p style="margin-top:var(--s2);">{birthstoneBlurb(mm)}</p></div>
      <div class="card card--pad"><p class="eyebrow eyebrow--coral">Birth flower · {flower}</p><p style="margin-top:var(--s2);">{flowerBlurb(mm)}</p></div>
    </div>
  </div>
</section>

<!-- ===== Released on this day (entertainment releases) ===== -->
{releaseGroups.length > 0 && (
  <section class="band band--tight">
    <div class="wrap">
      <div class="section-head">
        <h2 style="font-size:var(--step-2);">Released on {mName} {dd}</h2>
        <span class="eyebrow eyebrow--soft">Movies, games, albums &amp; shows</span>
      </div>
      <div class="stack" style="margin-top:var(--s4);">
        {releaseGroups.map((g) => (
          <div>
            <h3 style="font-size:var(--step-1);color:var(--gold-deep);">{g.year}</h3>
            <ul class="mini-list" style="margin-top:var(--s2);">
              {g.releases.map((r) => (
                <li>
                  <span class="mini-list__year">{verticalLabel(r.vertical)}</span>
                  <span class="mini-list__text">{r.amazonUrl
                    ? <a href={r.amazonUrl} target="_blank" rel="sponsored nofollow noopener">{r.title}</a>
                    : r.title}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <p class="muted" style="margin-top:var(--s4);font-size:var(--step--1);">Release data from TMDB &amp; IGDB. As an Amazon Associate, DateLore earns from qualifying purchases.</p>
    </div>
  </section>
)}

<!-- ===== Main two-column ===== -->
<section class="band band--tight">
  <div class="wrap day-layout">
    <div class="stack-lg">
      <!-- Timeline -->
      <div>
        <div class="section-head">
          <h2>Events</h2>
          <span class="eyebrow eyebrow--soft">{events.length} notable moments</span>
        </div>
        <ol class="timeline">
          {events.map((e) => (
            <li class="timeline__item">
              <span class="timeline__year">{e.year}</span>
              <div class="timeline__body">
                <h3 class="timeline__title">{e.title}</h3>
              </div>
            </li>
          ))}
        </ol>
      </div>

      <!-- Famous birthday twins -->
      <div>
        <div class="section-head">
          <h2>Famous birthday twins</h2>
          <span class="eyebrow eyebrow--coral">Born on {mName} {dd}</span>
        </div>
        <div class="twins">
          {births.map((b) => (
            <article class="twin">
              <span class="twin__monogram" aria-hidden="true">{b.monogram}</span>
              <div><h3 class="twin__name">{b.name}</h3><p class="twin__year">b. {b.year}</p></div>
            </article>
          ))}
        </div>
      </div>

      <!-- Deaths + Holidays -->
      <div class="grid" style="grid-template-columns:1fr;gap:var(--s6);">
        <div class="card card--pad">
          <div class="section-head" style="margin-bottom:var(--s4);">
            <h2 style="font-size:var(--step-2);">Deaths</h2>
          </div>
          <ul class="mini-list">
            {deaths.map((d) => (
              <li><span class="mini-list__year">{d.year}</span><span class="mini-list__text">{d.name}</span></li>
            ))}
          </ul>
        </div>
        <div class="card card--pad">
          <div class="section-head" style="margin-bottom:var(--s4);">
            <h2 style="font-size:var(--step-2);">Holidays &amp; observances</h2>
          </div>
          <ul class="mini-list">
            {entry.observances.map((o) => (
              <li><span class="mini-list__year">—</span><span class="mini-list__text" set:html={o.text}></span></li>
            ))}
          </ul>
        </div>
      </div>

      <p class="muted" style="font-size:var(--step--1);">
        The factual record above — events, births, deaths and observances — is compiled from <a href="https://en.wikipedia.org/" rel="noopener">Wikipedia</a> (<a href="https://creativecommons.org/licenses/by-sa/4.0/" rel="noopener">CC BY-SA</a>). The summaries and analysis are DateLore's own.
      </p>

      <!-- Born on this day CTA -->
      <div class="bcard" data-bday-scope>
        <p class="bcard__eyebrow">Born on this day?</p>
        <h2 class="bcard__date" style="color:var(--on-dark);">Make your birthday card.</h2>
        <p style="color:color-mix(in oklch, var(--on-dark) 86%, transparent);max-width:46ch;">
          Drop in your birth year and we'll work out your exact age, the day of the week you were born, your Chinese zodiac, your generation, and the countdown to your next candle.
        </p>
        <form class="bday-form" data-bday-form style="margin-top:var(--s5);">
          <div class="field">
            <label for="bd-day">Your date of birth</label>
            <input type="date" id="bd-day" data-bday-input required>
          </div>
          <button class="btn btn--coral" type="submit">Reveal my card →</button>
        </form>
        <p data-bday-error hidden style="margin-top:var(--s3);color:var(--gold);">Please pick a valid date in the past.</p>
        <div data-bday-results hidden style="margin-top:var(--s5);">
          <div class="stats">
            <div class="stat stat--coral"><div class="stat__num" data-bday-out="years">—</div><div class="stat__label">Years old</div></div>
            <div class="stat" style="background:color-mix(in oklch,var(--on-dark) 14%,transparent);border-color:transparent;color:var(--on-dark);"><div class="stat__num" data-bday-out="days" style="color:var(--on-dark);">—</div><div class="stat__label" style="color:color-mix(in oklch,var(--on-dark) 75%,transparent);">Days lived</div></div>
            <div class="stat" style="background:color-mix(in oklch,var(--on-dark) 14%,transparent);border-color:transparent;color:var(--on-dark);"><div class="stat__num" data-bday-out="weekday" style="color:var(--on-dark);font-size:var(--step-2);">—</div><div class="stat__label" style="color:color-mix(in oklch,var(--on-dark) 75%,transparent);">Day you were born</div></div>
          </div>
          <p style="margin-top:var(--s4);"><a href="/birthday/" style="color:var(--gold);">See the full birthday card →</a></p>
        </div>
      </div>
    </div>

    <!-- Sticky rail -->
    <aside class="day-rail stack">
      <div class="card card--gold card--pad">
        <p class="eyebrow">Daily quiz</p>
        <h2 style="font-size:var(--step-2);margin-top:var(--s2);">Which year did it happen?</h2>
        <p class="muted" style="margin-top:var(--s2);">One question a day. Keep your streak alive.</p>
        <a class="btn btn--primary" href="/quiz/" style="margin-top:var(--s4);width:100%;">Play today's quiz</a>
      </div>

      <nav class="card card--pad" aria-label="Nearby dates">
        <p class="eyebrow eyebrow--soft">Wander the calendar</p>
        <ul style="list-style:none;padding:0;margin-top:var(--s3);display:grid;gap:var(--s2);">
          <li><a href={`/${toSlug(prevKey)}/`} style="text-decoration:none;color:var(--ink-soft);">‹ {label(prevKey)}</a></li>
          <li><a href={`/${toSlug(nextKey)}/`} style="text-decoration:none;color:var(--ink-soft);">{label(nextKey)} ›</a></li>
          <li><a href={`/${monthSlug}/`} style="text-decoration:none;color:var(--gold-deep);">All of {mName} →</a></li>
          <li><a href="/birthday/" style="text-decoration:none;color:var(--ink-soft);">Your birthday →</a></li>
        </ul>
      </nav>
    </aside>
  </div>
</section>

<style>
  /* The essay body is compiled markdown, so target its descendants with :global. */
  .essay-prose :global(p) { margin-top: var(--s3); line-height: 1.7; }
  .essay-prose :global(h3) { margin-top: var(--s5); font-size: var(--step-1); }
  .essay-prose :global(a) { color: var(--gold-deep); }
  .essay-prose :global(blockquote) {
    margin-top: var(--s4);
    padding-left: var(--s4);
    border-left: 3px solid var(--gold-deep);
    color: var(--ink-soft);
  }
</style>
