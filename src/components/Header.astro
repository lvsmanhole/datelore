---
import BrandMark from './BrandMark.astro';
import { MONTHS } from '../lib/slug';
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isDay = path !== '/' && !['/birthday', '/quiz', '/share'].includes(path) && !path.startsWith('/releases');
---
<header class="site-header">
  <div class="wrap site-header__inner">
    <a class="wordmark" href="/"><BrandMark class="wordmark__mark" /> DateLore</a>
    <nav class="nav" aria-label="Primary">
      <ul>
        <li><a href="/may-31" data-today-link aria-current={isDay ? 'page' : undefined}>Today</a></li>
        <li><a href="/releases/" aria-current={path.startsWith('/releases') ? 'page' : undefined}>Releases</a></li>
        <li><a href="/birthday" aria-current={path === '/birthday' ? 'page' : undefined}>Your Birthday</a></li>
        <li><a href="/quiz" aria-current={path === '/quiz' ? 'page' : undefined}>Daily Quiz</a></li>
      </ul>
    </nav>
    <form class="quick-date hide-sm" role="search" aria-label="Jump to a date" data-quick-date-form>
      <label for="qd-month">Go to date</label>
      <select id="qd-month" data-quick-month aria-describedby="qd-error">
        <option value="">Month</option>
        {MONTHS.map((m, i) => <option value={i + 1}>{m}</option>)}
      </select>
      <select id="qd-day" data-quick-day aria-label="Day" aria-describedby="qd-error">
        <option value="">Day</option>
        {Array.from({ length: 31 }, (_, i) => <option value={i + 1}>{i + 1}</option>)}
      </select>
      <span id="qd-error" class="visually-hidden" role="alert" data-quick-date-error hidden>Pick a valid date.</span>
    </form>
  </div>
</header>
