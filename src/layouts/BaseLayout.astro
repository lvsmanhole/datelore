---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const {
  title = 'DateLore — On This Day, Your Birthday & a Daily History Quiz',
  description = "What happened on this day in history, the story of the day you were born, and a daily 'which year?' quiz. A warm almanac of every date.",
  ogImage,
  ogType = 'website',
  jsonld = [],
  noindex = false,
} = Astro.props as {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  jsonld?: object[];
  noindex?: boolean;
};

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImageUrl = ogImage ? new URL(ogImage, Astro.site).href : undefined;
// Escape `<` so a stray "</script>" inside any string can't break out of the tag.
const ldScripts = jsonld.map((node) => JSON.stringify(node).replace(/</g, '\\u003c'));
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Ezoic — must sit as high in <head> as possible. Privacy (CMP) scripts load
        FIRST so consent is handled before the ad header script. is:inline keeps
        Astro from bundling/reordering them; data-cfasync="false" stops Cloudflare
        Rocket Loader from touching the consent scripts. */}
    <script is:inline data-cfasync="false" src="https://cmp.gatekeeperconsent.com/min.js"></script>
    <script is:inline data-cfasync="false" src="https://the.gatekeeperconsent.com/cmp.min.js"></script>
    <script is:inline async src="https://www.ezojs.com/ezoic/sa.min.js"></script>
    <script is:inline>
      window.ezstandalone = window.ezstandalone || {};
      ezstandalone.cmd = ezstandalone.cmd || [];
    </script>
    <script is:inline src="https://ezoicanalytics.com/analytics.js"></script>

    {/* Google AdSense — account verification + Auto-ads loader. Present so AdSense
        can review/verify the site. Keep Auto ads OFF in the AdSense dashboard while
        Ezoic is managing placements, to avoid double-serving. */}
    <script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-9423816375028161" crossorigin="anonymous"></script>

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, follow" />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/og/logo.png" />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
    <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />

    {ldScripts.map((json) => (
      <script type="application/ld+json" is:inline set:html={json} />
    ))}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;0,6..72,700;1,6..72,400;1,6..72,500&display=swap"
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <Header />
    <main id="main">
      <slot />
    </main>
    <Footer />
    <script>
      import '../scripts/datelore.ts';
    </script>
  </body>
</html>
